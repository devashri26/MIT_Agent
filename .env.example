# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Recommended: Groq (free tier: 30 RPM / 14,400 RPD on 8B model — much higher than Gemini).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Or use Gemini (free tier: 10 RPM / 250 RPD on gemini-2.5-flash):
# GOOGLE_API_KEY=your-gemini-api-key-here

# Or use OpenAI / Anthropic (require billing):
# OPENAI_API_KEY=...
# ANTHROPIC_API_KEY=...

# Optional overrides:
# LLM_PROVIDER=groq         # one of: groq, gemini, anthropic, openai, mock
# QDRANT_URL=               # set to use a remote Qdrant instead of local file-based mode
