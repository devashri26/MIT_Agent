# Copy this file to `.env` and fill in your key. `.env` is gitignored.
# Required for live answers via /chat and /chat/stream:
GOOGLE_API_KEY=your-gemini-api-key-here

# Optional overrides:
# LLM_PROVIDER=gemini       # one of: gemini, anthropic, openai, mock
# QDRANT_URL=               # set to use a remote Qdrant instead of local file-based mode
